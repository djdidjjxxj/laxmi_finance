{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://laxmi-finance.onrender.com/api/:path*"
    },
    {
      "source": "/sanctum/:path*",
      "destination": "https://laxmi-finance.onrender.com/sanctum/:path*"
    },
    {
      "source": "/((?!assets/|favicon.ico|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}
